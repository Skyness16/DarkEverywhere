{
  "manifest_version": 3,
  "name": "Dark Everywhere",
  "version": "1.6.2",
  "description": "Modo oscuro en páginas web (inversión inteligente, compatible con Chrome/Edge).",
  "minimum_chrome_version": "109",
  "icons": {
    "16": "assets/icon.png",
    "32": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_title": "Dark Everywhere",
    "default_icon": {
      "16": "assets/icon.png",
      "32": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "scripts/shared/constants.js",
        "scripts/shared/storage-adapter.js",
        "scripts/content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": ["storage"],
  "background": {
    "service_worker": "scripts/background/background.js"
  },
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "Activar o desactivar modo oscuro"
    }
  }
}
